auto-update = check
auto-update-channel = tip

# Readability.
# background-opacity = 0.9
# background-blur-radius = 20
# background = #031219
font-size = 16
font-family = SFMono Nerd Font 
scrollback-limit = 50000000
theme = vitesse-dark

# Window behavior.
window-save-state = always
window-padding-x = 6
window-padding-y = 6
confirm-close-surface = true
quit-after-last-window-closed = false

# Input/selection behavior.
mouse-hide-while-typing = true
cursor-style-blink = true

# macOS ergonomics: keep one Option key for symbols, one for Alt bindings.
macos-option-as-alt = left

# Faster split/pane management (keeps Ghostty defaults too).
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right
keybind = super+ctrl+h=resize_split:left,5
keybind = super+ctrl+j=resize_split:down,5
keybind = super+ctrl+k=resize_split:up,5
keybind = super+ctrl+l=resize_split:right,5
keybind = super+ctrl+0=equalize_splits
