[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
	verbose = true
[user]
	name = stuckinforloop
	email = device.neel@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPfBJEL3jXncpwUwMX7BAoeLSHDFlKlGUrB/HPCabVgF
[github]
	user = stuckinforloop
[init]
	defaultBranch = master
	templateDir = ~/.git-templates
[core]
	editor = nvim
	excludesfile = ~/.config/git/ignore
[push]
	default = simple
	autoSetupRemote = true
	followTags = true
[pull]
	rebase = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[rerere]
	enabled = true
	autoUpdate = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[url "git@github.com:"]
	insteadOf = https://github.com/
